datasource db {
	provider = "mysql"
}

generator client {
	provider = "prisma-client"
	output = "../src/generated/prisma"
}

model Player {
	id			Int			@id @default(autoincrement())
	name		String		@db.VarChar(36)
	player		String		@unique @db.VarChar(36)
	role		String		@default("player") @db.VarChar(20)
	vip			Int			@default(0)
	tas			Int			@default(0)
	date		DateTime	@default(dbgenerated("'2025-01-01 00:00:00'"))
	@@map("players")
}

model Leaderboard {
	id		Int			@id @default(autoincrement())
	map		String		@db.VarChar(100)
	player	String		@db.VarChar(36)
	name	String		@db.VarChar(36)
	mode	String		@db.VarChar(20)
	way		String		@db.VarChar(20)
	time	Int
	run		String		@db.VarChar(36)
	tas		Int			@default(0)
	date	DateTime	@default(dbgenerated("'2025-01-01 00:00:00'"))
	@@map("leaderboards")
	@@index([map, mode, way, tas, time])
}

model PB {
	id		Int			@id @default(autoincrement())
	map		String		@db.VarChar(100)
	player	String		@db.VarChar(36)
	name	String		@db.VarChar(36)
	mode	String		@db.VarChar(20)
	way		String		@db.VarChar(20)
	time	Int
	run		String		@db.VarChar(36)
	date	DateTime	@default(dbgenerated("'2025-01-01 00:00:00'"))
	@@map("pbs")
}
